[
  {
    "groupKey": "image",
    "label": "副本与镜像",
    "icon": "🐳",
    "description": "应用副本数及容器镜像配置",
    "fields": [
      {
        "key": "replicaCount",
        "label": "副本数",
        "type": "number",
        "defaultValue": 1,
        "yamlPath": "replicaCount",
        "min": 1,
        "max": 10,
        "span": 12
      },
      {
        "key": "repository",
        "label": "镜像仓库地址",
        "type": "string",
        "required": true,
        "defaultValue": "harbor.zkjgy.online/library/write-to-kafka",
        "yamlPath": "image.repository",
        "placeholder": "如 harbor.zkjgy.online/library/write-to-kafka",
        "span": 24
      },
      {
        "key": "tag",
        "label": "镜像版本",
        "type": "string",
        "defaultValue": "latest",
        "yamlPath": "image.tag",
        "placeholder": "如 latest、v1.0.0",
        "span": 12
      },
      {
        "key": "pullPolicy",
        "label": "镜像拉取策略",
        "type": "select",
        "defaultValue": "IfNotPresent",
        "yamlPath": "image.pullPolicy",
        "options": [
          { "label": "IfNotPresent - 本地有则用本地", "value": "IfNotPresent" },
          { "label": "Always - 每次都拉取最新", "value": "Always" },
          { "label": "Never - 仅使用本地镜像", "value": "Never" }
        ],
        "span": 12
      }
    ]
  },
  {
    "groupKey": "scheduling",
    "label": "边缘节点调度",
    "icon": "🖥️",
    "description": "KubeEdge 边缘节点的调度策略与网络模式",
    "fields": [
      {
        "key": "hostNetwork",
        "label": "使用主机网络",
        "type": "boolean",
        "defaultValue": true,
        "yamlPath": "hostNetwork",
        "description": "开启后容器可直接访问 MQTT Broker / Kafka 的节点物理 IP",
        "span": 12
      },
      {
        "key": "dnsPolicy",
        "label": "DNS 策略",
        "type": "select",
        "defaultValue": "ClusterFirstWithHostNet",
        "yamlPath": "dnsPolicy",
        "options": [
          { "label": "ClusterFirstWithHostNet", "value": "ClusterFirstWithHostNet" },
          { "label": "ClusterFirst", "value": "ClusterFirst" },
          { "label": "Default", "value": "Default" },
          { "label": "None", "value": "None" }
        ],
        "span": 12
      }
    ]
  },
  {
    "groupKey": "resources",
    "label": "资源限制",
    "icon": "💾",
    "description": "容器 CPU 与内存的资源申请值及上限",
    "fields": [
      {
        "key": "requestsCpu",
        "label": "CPU 申请值",
        "type": "string",
        "defaultValue": "200m",
        "yamlPath": "resources.requests.cpu",
        "placeholder": "如 200m、500m",
        "span": 12
      },
      {
        "key": "requestsMemory",
        "label": "内存申请值",
        "type": "string",
        "defaultValue": "256Mi",
        "yamlPath": "resources.requests.memory",
        "placeholder": "如 256Mi、512Mi",
        "span": 12
      },
      {
        "key": "limitsCpu",
        "label": "CPU 上限",
        "type": "string",
        "defaultValue": "1000m",
        "yamlPath": "resources.limits.cpu",
        "placeholder": "如 1000m、2",
        "span": 12
      },
      {
        "key": "limitsMemory",
        "label": "内存上限",
        "type": "string",
        "defaultValue": "512Mi",
        "yamlPath": "resources.limits.memory",
        "placeholder": "如 512Mi、1Gi",
        "span": 12
      }
    ]
  },
  {
    "groupKey": "kafka",
    "label": "Kafka 连接配置",
    "icon": "📨",
    "description": "Kafka Broker 地址、SASL 认证及 Kerberos 参数",
    "fields": [
      {
        "key": "kafkaBrokers",
        "label": "Kafka Broker 列表",
        "type": "textarea",
        "required": true,
        "defaultValue": "[\"10.81.151.147:21007\",\"10.81.151.148:21007\",\"10.81.151.149:21007\"]",
        "yamlPath": "env.KAFKA__BROKERS",
        "description": "JSON 数组格式，多个 Broker 地址",
        "span": 24
      },
      {
        "key": "saslMechanism",
        "label": "SASL 机制",
        "type": "select",
        "defaultValue": "gssapi",
        "yamlPath": "env.KAFKA__SASL_MECHANISM",
        "options": [
          { "label": "gssapi - Kerberos", "value": "gssapi" },
          { "label": "plain - 用户名/密码", "value": "plain" },
          { "label": "scram-sha-256", "value": "scram-sha-256" },
          { "label": "scram-sha-512", "value": "scram-sha-512" }
        ],
        "span": 12
      },
      {
        "key": "saslUser",
        "label": "SASL 用户名",
        "type": "string",
        "defaultValue": "gyhlw",
        "yamlPath": "env.KAFKA__SASL_USER",
        "span": 12
      },
      {
        "key": "saslPassword",
        "label": "SASL 密码",
        "type": "password",
        "defaultValue": "Huawei12#$%",
        "yamlPath": "env.KAFKA__SASL_PASSWORD",
        "span": 12
      },
      {
        "key": "saslRealm",
        "label": "Kerberos Realm",
        "type": "string",
        "defaultValue": "HADOOP.COM",
        "yamlPath": "env.KAFKA__SASL_GSSAPI_REALM",
        "span": 12
      },
      {
        "key": "saslServiceName",
        "label": "Kerberos 服务名",
        "type": "string",
        "defaultValue": "kafka",
        "yamlPath": "env.KAFKA__SASL_GSSAPI_SERVICE_NAME",
        "span": 12
      },
      {
        "key": "saslDomainName",
        "label": "Kerberos 域名",
        "type": "string",
        "defaultValue": "hadoop.hadoop.com",
        "yamlPath": "env.KAFKA__SASL_GSSAPI_DOMAIN_NAME",
        "span": 12
      }
    ]
  },
  {
    "groupKey": "pipelines",
    "label": "数据管道配置",
    "icon": "🔀",
    "description": "MQTT → Kafka 数据转发管道（多电厂多 Broker）",
    "fields": [
      {
        "key": "pipelines",
        "label": "管道配置 JSON",
        "type": "textarea",
        "required": true,
        "defaultValue": "[{\"mqtt_topic\":\"device/sis/data\",\"kafka_topic\":\"gyhlw_sd03001\",\"mqtt_broker\":\"tcp://10.66.87.82\",\"mqtt_port\":11883,\"mqtt_qos\":1,\"points_file\":\"/etc/config/points_dongying.csv\"}]",
        "yamlPath": "env.PIPELINES",
        "description": "JSON 数组。每元素定义一条管道：mqtt_topic(源)/kafka_topic(目标)/mqtt_broker/mqtt_port/mqtt_qos/points_file",
        "span": 24
      }
    ]
  },
  {
    "groupKey": "fileMounts",
    "label": "文件挂载",
    "icon": "📁",
    "description": "Kerberos 配置及点表 CSV 文件的 hostPath 挂载",
    "fields": [
      {
        "key": "krb5HostPath",
        "label": "krb5.conf 主机路径",
        "type": "string",
        "required": true,
        "defaultValue": "/data/write-to-kafka/kerberos/krb5.conf",
        "yamlPath": "krb5Config.hostPath",
        "description": "边缘节点上 Kerberos 配置文件的绝对路径",
        "span": 12
      },
      {
        "key": "krb5MountPath",
        "label": "krb5.conf 挂载路径",
        "type": "string",
        "defaultValue": "/etc/krb5.conf",
        "yamlPath": "krb5Config.mountPath",
        "span": 12
      }
    ]
  }
]
